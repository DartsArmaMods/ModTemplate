{
    "version": "2.0.0",
    "tasks": [
        {
            // Default build task, press Ctrl+Shift+B to build dev version and launch
            "label": "HEMTT Launch",
            "command": "hemtt.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "launch"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            // Builds the addon of the file you're editing
            "label": "HEMTT Build --just",
            "command": "python",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "tools/build_current_addon.py",
                "${relativeFile}"
            ],
            "group": {
                "kind": "build"
            }
        }
    ]
}
